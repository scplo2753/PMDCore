DEFINE_int32(basic, 0, "only output reads with a C>T mismatch this many basepairs from the 5' end")
DEFINE_string(chromosome, "", "only process the specified chromosome")
DEFINE_bool(CpG, false, "only use Cs and Gs in CpG context")
DEFINE_bool(noinsertion, false, "no insertion")
DEFINE_bool(nodeletion, false, "no deletion")
DEFINE_bool(onlyinsertions, false, "only insertions")
DEFINE_bool(onlydeletions, false, "only deletions")
DEFINE_bool(noindels, false, "no indels")
DEFINE_bool(noclips,false, "no clips")
DEFINE_bool(onlyclips, false, "only clips")
DEFINE_bool(noreverse,false, "only no reverse line")
DEFINE_uint32(requirebaseq, 0, "only process bases with base quality at least this great")
DEFINE_int32(requiremapq, 0, "require minimum mapping quality")
DEFINE_uint32(readlength,0,"only process reads with the specified length")
DEFINE_uint32(maxlength,0,"only process reads with length less than or equal to the specified length")
DEFINE_uint32(minlength,0,"only process reads with length greater than or equal to the specified length")
DEFINE_int32(maskterminalbases, 0, "mask terminal bases")
DEFINE_int32(maskterminaldeaminations, 0, "mask terminal bases")
DEFINE_bool(basecomposition, false, "basecomposition")
DEFINE_double(maxGC, 1.0, "only process sequences with max this GC content of the aligning reference sequence")
DEFINE_double(minGC, 0.0, "only process sequences with min this GC content of the aligning reference sequence")
DEFINE_bool(writesamfield, false, "add 'DS:Z:<PMDS>' field to SAM output, will overwrite if already present")
//platypus
DEFINE_bool(platypus, false, "output big list of base frequencies for platypus")
//class calPMD.compute degratation score
DEFINE_double(PMDpparam, 0.3, "parameter p in geometric probability distribution of PMD")
DEFINE_double(PMDconstant, 0.01, "constant C in geometric probability distribution of PMD")
DEFINE_double(polymorphism_ancient, 0.001, "True biological polymorphism between the ancient individual and the reference sequence")
DEFINE_double(polymorphism_contamination, 0.001, "True biological polymorphism between the contaminants and the reference sequence")

DEFINE_bool(ss, false, "single stranded")
DEFINE_int32(range, 30, "output deamination patterns for this many positions from the sequence terminus (default=30)")

DEFINE_double(threshold,-20000.0,"only output sequences with PMD score above this threshold")
DEFINE_double(upperthreshold,1000000.0,"only output sequences with PMD score below this threshold")
DEFINE_bool(terminal,false,"only output reads with a C>T mismatch this many basepairs from the 5' end")